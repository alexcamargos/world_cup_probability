WITH team_match_history AS (
    SELECT
        f_matches.match_id,
        f_matches.match_date,
        f_matches.competition,
        f_matches.home_team_id AS team_id,
        f_matches.away_team_id AS opponent_team_id,
        f_matches.home_team_score AS goals_for,
        f_matches.away_team_score AS goals_against,
        {{ home_match_stats_selects }}
    FROM f_matches
    {{ home_match_stats_joins }}
    WHERE {{ match_history_exclusion }}
    UNION ALL
    SELECT
        f_matches.match_id,
        f_matches.match_date,
        f_matches.competition,
        f_matches.away_team_id AS team_id,
        f_matches.home_team_id AS opponent_team_id,
        f_matches.away_team_score AS goals_for,
        f_matches.home_team_score AS goals_against,
        {{ away_match_stats_selects }}
    FROM f_matches
    {{ away_match_stats_joins }}
    WHERE {{ match_history_exclusion }}
),

latest_world_cup_probability_elo AS (
    SELECT
        team_id,
        world_cup_probability_elo_now
    FROM (
        SELECT
            team_id,
            world_cup_probability_elo_now,
            ROW_NUMBER() OVER (
                PARTITION BY team_id
                ORDER BY match_date DESC, match_id DESC
            ) AS rn
        FROM (
            SELECT
                e.match_id,
                e.match_date,
                e.home_team_id AS team_id,
                e.home_rating_after AS world_cup_probability_elo_now
            FROM f_elo_history AS e
            INNER JOIN f_matches AS m
                ON e.match_id = m.match_id
            WHERE {{ elo_history_exclusion }}
            UNION ALL
            SELECT
                e.match_id,
                e.match_date,
                e.away_team_id AS team_id,
                e.away_rating_after AS world_cup_probability_elo_now
            FROM f_elo_history AS e
            INNER JOIN f_matches AS m
                ON e.match_id = m.match_id
            WHERE {{ elo_history_exclusion }}
        ) AS elo_union
    ) AS ranked
    WHERE rn = 1
),
{{ world_football_elo_ratings_cte }}
{{ fifa_world_ranking_cte }}
{{ squad_attributes_ctes }}
{{ world_cup_prior_history_cte }}
{{ world_cup_prior_discipline_cte }}
recent_form AS (
    SELECT
        team_id,
        COALESCE(
            AVG(goals_for) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS goals_for_last5,
        COALESCE(
            AVG(goals_against) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS goals_against_last5,
        COALESCE(
            AVG(xg_for) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_xg_for,
        COALESCE(
            AVG(xg_against) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_xg_against,
        COALESCE(
            AVG(possession_pct) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_possession_pct,
        COALESCE(
            AVG(shots_for) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_shots_for,
        COALESCE(
            AVG(shots_against) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_shots_against,
        COALESCE(
            AVG(shots_on_target_for) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_shots_on_target_for,
        COALESCE(
            AVG(shots_on_target_against) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_shots_on_target_against,
        COALESCE(
            AVG(corners_for) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_corners_for,
        COALESCE(
            AVG(corners_against) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_corners_against,
        COALESCE(
            AVG(yellow_cards) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_yellow_cards,
        COALESCE(
            AVG(red_cards) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_red_cards,
        COALESCE(
            AVG(goals_for - goals_against) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS opponent_adjusted_recent_form,
        COALESCE(
            AVG(
                CASE
                    WHEN lower(coalesce(competition, '')) NOT LIKE '%friendly%'
                     AND lower(coalesce(competition, '')) NOT LIKE '%amistoso%'
                    THEN goals_for - goals_against
                    ELSE NULL
                END
            ) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_official_form,
        COALESCE(
            AVG(
                CASE
                    WHEN lower(coalesce(competition, '')) LIKE '%friendly%'
                      OR lower(coalesce(competition, '')) LIKE '%amistoso%'
                    THEN goals_for - goals_against
                    ELSE NULL
                END
            ) OVER (
                PARTITION BY team_id
                ORDER BY match_date, match_id
                ROWS BETWEEN 5 PRECEDING AND 1 PRECEDING
            ),
            0.0
        ) AS recent_friendly_form,
        ROW_NUMBER() OVER (
            PARTITION BY team_id
            ORDER BY match_date DESC, match_id DESC
        ) AS rn
    FROM team_match_history
),

latest_form AS (
    SELECT
        team_id,
        goals_for_last5 - goals_against_last5 AS recent_form,
        recent_xg_for,
        recent_xg_against,
        recent_possession_pct,
        recent_shots_for,
        recent_shots_against,
        recent_shots_on_target_for,
        recent_shots_on_target_against,
        recent_corners_for,
        recent_corners_against,
        recent_yellow_cards,
        recent_red_cards,
        opponent_adjusted_recent_form,
        recent_official_form,
        recent_friendly_form
    FROM recent_form
    WHERE rn = 1
)
SELECT
    t.team_id,
    t.team_name,
    COALESCE(le.world_cup_probability_elo_now, 1500.0) AS world_cup_probability_elo_now,
    {{ world_football_elo_ratings_select }},
    {{ fifa_world_ranking_points_select }},
    {{ fifa_world_ranking_rank_select }},
    {{ world_cup_prior_history_selects }}
    {{ world_cup_prior_discipline_selects }}
    COALESCE(t.market_value_eur, 0.0) AS market_value_eur,
    {{ squad_attributes_select }}
    COALESCE(lf.recent_form, 0.0) AS recent_form,
    COALESCE(lf.recent_xg_for, 0.0) AS recent_xg_for,
    COALESCE(lf.recent_xg_against, 0.0) AS recent_xg_against,
    COALESCE(lf.recent_possession_pct, 0.0) AS recent_possession_pct,
    COALESCE(lf.recent_shots_for, 0.0) AS recent_shots_for,
    COALESCE(lf.recent_shots_against, 0.0) AS recent_shots_against,
    COALESCE(lf.recent_shots_on_target_for, 0.0) AS recent_shots_on_target_for,
    COALESCE(lf.recent_shots_on_target_against, 0.0) AS recent_shots_on_target_against,
    COALESCE(lf.recent_corners_for, 0.0) AS recent_corners_for,
    COALESCE(lf.recent_corners_against, 0.0) AS recent_corners_against,
    COALESCE(lf.recent_yellow_cards, 0.0) AS recent_yellow_cards,
    COALESCE(lf.recent_red_cards, 0.0) AS recent_red_cards,
    COALESCE(lf.opponent_adjusted_recent_form, 0.0) AS opponent_adjusted_recent_form,
    COALESCE(lf.recent_official_form, 0.0) AS recent_official_form,
    COALESCE(lf.recent_friendly_form, 0.0) AS recent_friendly_form,
    0.0 AS is_friendly_match
FROM d_teams AS t
LEFT JOIN latest_world_cup_probability_elo AS le
    ON t.team_id = le.team_id
{{ world_football_elo_ratings_join }}
{{ fifa_world_ranking_join }}
{{ world_cup_prior_history_join }}
{{ world_cup_prior_discipline_join }}
{{ squad_attributes_join }}
LEFT JOIN latest_form AS lf
    ON t.team_id = lf.team_id
ORDER BY world_cup_probability_elo_now DESC, market_value_eur DESC, t.team_name ASC
